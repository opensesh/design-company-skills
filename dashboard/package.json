{
  "name": "@design-ops/dashboard",
  "version": "1.0.0",
  "description": "Live web dashboard for DESIGN-OPS with direct API integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,magenta \"npm:dev:server\" \"npm:dev:ui\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:ui": "npm --prefix ui run dev",
    "build": "npm --prefix ui run build && tsc",
    "build:server": "tsc",
    "build:ui": "npm --prefix ui run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@notionhq/client": "^2.2.15",
    "fastify": "^4.28.1",
    "googleapis": "^140.0.1",
    "node-cache": "^5.1.2",
    "octokit": "^4.0.2",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "concurrently": "^9.2.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
